    "dist"
  ],
  "keywords": [
    "typing",
    "typewriter",
    "live-coding",
    "presentation",
    "demo",
    "screencast",
    "typing-simulator",
    "teleprompter",
    "auto-type"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SidyKing/typeghost.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/SidyKing/typeghost#readme",
  "bugs": {
    "url": "https://github.com/SidyKing/typeghost/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
