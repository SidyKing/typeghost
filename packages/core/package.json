{
  "name": "@typeghost/core",
  "version": "0.1.0",
  "description": "Human-like code typing engine — the heart of TypeGhost. Replay pre-written code with realistic rhythm, corrected typos and checkpoints, in any editor you can adapt it to.",
  "license": "MIT",
